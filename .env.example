# Supabase Auth for login, create account, and Google OAuth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side Supabase. Leave empty for demo-memory mode.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Device secret used by ESP32/RFID device when calling /api/device/tap.
DEVICE_SECRET=DEV-SECRET-CHANGE-ME

# Demo fallback login when Supabase is not configured.
ADMIN_EMAIL=admin@kantor.local
ADMIN_PASSWORD=admin123
